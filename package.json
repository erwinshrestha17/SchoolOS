{
  "name": "schoolos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @schoolos/api --filter @schoolos/web dev",
    "build": "pnpm --filter @schoolos/api build && pnpm --filter @schoolos/web build",
    "lint": "pnpm --filter @schoolos/api format:check && pnpm --filter @schoolos/web lint",
    "typecheck": "pnpm --filter @schoolos/api typecheck && pnpm --filter @schoolos/web typecheck",
    "test": "pnpm --filter @schoolos/api test && pnpm --filter @schoolos/web test",
    "test:e2e": "pnpm --filter @schoolos/api test:e2e",
    "db:generate": "pnpm --filter @schoolos/api prisma:generate",
    "db:validate": "pnpm --filter @schoolos/api exec prisma validate --schema prisma/schema.prisma",
    "db:migrate": "pnpm --filter @schoolos/api db:migrate",
    "db:seed": "pnpm --filter @schoolos/api db:seed",
    "db:seed:platform": "pnpm --filter @schoolos/api db:seed:platform",
    "test:web:e2e": "pnpm --filter @schoolos/web test:e2e",
    "verify:env:deploy": "node scripts/check-deploy-env.mjs",
    "verify:tracked-artifacts": "node scripts/check-tracked-artifacts.mjs",
    "verify:openapi": "node scripts/check-openapi-gate.mjs",
    "verify:deploy:core": "pnpm verify:env:deploy && pnpm verify:tracked-artifacts && pnpm db:generate && pnpm db:validate && pnpm verify:openapi && pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e && pnpm build",
    "verify:deploy": "pnpm verify:deploy:core && pnpm test:web:e2e",
    "verify:production": "pnpm verify:deploy",
    "smoke:phase1": "node scripts/smoke-phase1-local.mjs"
  }
}
