  updatedAt       DateTime @updatedAt

  tenant              Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  route               TransportRoute               @relation(fields: [routeId], references: [id], onDelete: Cascade)
  enrollments         TransportEnrollment[]
  logs                TransportLog[]
  studentAssignments  TransportStudentAssignment[]
  tripStudentStatuses TransportTripStudentStatus[]

  @@unique([tenantId, routeId, sequence])
  @@index([tenantId, routeId])
}

model TransportVehicle {
  id                    String                 @id @default(uuid())
