generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Mode {
  SINGLE
  MULTI
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AuthMethod {
  PASSWORD
  OTP
  BOTH
}

enum OtpPurpose {
  LOGIN
  RESET
  VERIFY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContractType {
  PERMANENT
  TEMPORARY
  PART_TIME
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  TRANSFERRED
  EXITED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  SICK_LEAVE
  EXCUSED_LEAVE
  UNEXCUSED_LEAVE
}

enum FeeFrequency {
  ONE_TIME
  MONTHLY
  TERM
  ANNUAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  BANK
  CHEQUE
  TRANSFER
  MOBILE
}

enum JournalSourceType {
  MANUAL
  INVOICE
  FEE_PAYMENT
  PAYMENT_REFUND
  PAYROLL
  CLOSING
  ADJUSTMENT
  REVERSAL
}

enum JournalLineSide {
  DEBIT
  CREDIT
}

enum ChartAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum NoticePriority {
  NORMAL
  URGENT
  EMERGENCY
}

enum AudienceType {
  ALL
  CLASS
  SECTION
  ROLE
}

enum EventType {
  GENERAL
  EXAM
  MEETING
  HOLIDAY
}

enum StorageProvider {
  LOCAL
  R2
}

enum StudentDocumentKind {
  BIRTH_CERTIFICATE
  TRANSFER_CERTIFICATE
  PHOTO
  ID_CARD
  ENROLLMENT_CONFIRMATION
  OTHER
}

enum AttendanceConflictStatus {
  NONE
  FLAGGED
  REVIEWED
}

enum AttendanceConflictDecision {
  REVIEWED_WITHOUT_CHANGE
  REVIEWED_AND_OVERRIDDEN
  REJECTED_RESUBMISSION
}

enum BillingRunStatus {
  DRAFT
  GENERATED
  VOID
}

enum DiscountType {
  SIBLING
  SCHOLARSHIP
  STAFF_CHILD
  MANUAL
}

enum WaiverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityCategory {
  LEARNING
  OUTDOOR_PLAY
  ART_AND_CRAFT
  CELEBRATION
  SPORTS
  GENERAL
}

enum MoodValue {
  CALM
  ENGAGED
  EXCITED
  UNSETTLED
  TIRED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum ConsentType {
  PRIVACY
  DATA_PROCESSING
  MEDICAL
  PHOTO_USAGE
  MESSAGING
}

enum AttendanceSyncStatus {
  ACCEPTED
  CONFLICTED
  REJECTED
}

enum AttendanceSyncRejectionReason {
  LOCKED_SESSION
  VALIDATION_ERROR
  ROSTER_MISMATCH
  REFERENCE_NOT_FOUND
  UNKNOWN
}

enum ActivityReactionType {
  HEART
  CLAP
  STAR
}

enum DevelopmentalMilestoneStatus {
  EMERGING
  PROGRESSING
  ACHIEVED
  NEEDS_SUPPORT
}

enum AssessmentType {
  TERMINAL
  CAS
  PRACTICAL
  PROJECT
}

enum GradeLockStatus {
  DRAFT
  LOCKED
}

enum HomeworkStatus {
  ASSIGNED
  SUBMITTED
  REVIEWED
  LATE
}

enum PayrollRunStatus {
  DRAFT
  REVIEWED
  APPROVED
  POSTED
  VOID
}

enum PayrollLineStatus {
  DRAFT
  APPROVED
  POSTED
}

enum PayslipStatus {
  DRAFT
  ISSUED
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum StudentLifecycleStatus {
  ACTIVE
  TRANSFERRED
  EXITED
  ALUMNI
  DELETED
}

enum GuardianIdentityVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  REVOKED
}

enum ConversationType {
  DIRECT
  CLASS
  SECTION
}

enum MessageStatus {
  SENT
  READ
}

enum LibraryCopyStatus {
  AVAILABLE
  ISSUED
  LOST
  DAMAGED
  RESERVED
}

enum LibraryIssueStatus {
  ISSUED
  RETURNED
  OVERDUE
  LOST
}

enum TransportVehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum TransportEnrollmentStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum TransportBoardingStatus {
  BOARDED
  DROPPED
  MISSED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  mode      Mode     @default(SINGLE)
  plan      String   @default("free")
  panNumber String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users                         User[]
  roles                         Role[]
  classes                       Class[]
  students                      Student[]
  subjects                      Subject[]
  staff                         Staff[]
  academicYears                 AcademicYear[]
  sections                      Section[]
  guardians                     Guardian[]
  studentGuardians              StudentGuardian[]
  enrollments                   Enrollment[]
  attendanceSessions            AttendanceSession[]
  attendanceRecords             AttendanceRecord[]
  staffAttendance               StaffAttendance[]
  feeHeads                      FeeHead[]
  feePlans                      FeePlan[]
  feePlanItems                  FeePlanItem[]
  studentFeeAssignments         StudentFeeAssignment[]
  invoices                      Invoice[]
  invoiceLines                  InvoiceLine[]
  payments                      Payment[]
  paymentRefunds                PaymentRefund[]
  cashierCloses                 CashierClose[]
  receipts                      Receipt[]
  chartAccounts                 ChartAccount[]
  journalEntries                JournalEntry[]
  journalLines                  JournalLine[]
  notices                       Notice[]
  events                        Event[]
  studentDocuments              StudentDocument[]
  siblingGroups                 SiblingGroup[]
  siblingGroupMembers           SiblingGroupMember[]
  attendanceConflicts           AttendanceConflict[]
  feeBillingRuns                FeeBillingRun[]
  feeDueSchedules               FeeDueSchedule[]
  discountRules                 DiscountRule[]
  feeWaivers                    FeeWaiver[]
  activityPosts                 ActivityPost[]
  activityAttachments           ActivityAttachment[]
  activityPostStudents          ActivityPostStudent[]
  activityReactions             ActivityReaction[]
  developmentalMilestones       DevelopmentalMilestone[]
  moodLogs                      MoodLog[]
  notificationDeliveries        NotificationDelivery[]
  guardianConsents              GuardianConsent[]
  guardianIdentityVerifications GuardianIdentityVerification[]
  generatedStudentDocuments     GeneratedStudentDocument[]
  lifecycleTransitions          StudentLifecycleTransition[]
  attendanceSyncSubmissions     AttendanceSyncSubmission[]
  teacherAssignments            SubjectTeacherAssignment[]
  examTerms                     ExamTerm[]
  examTimetableSlots            ExamTimetableSlot[]
  markLockRequests              MarkLockRequest[]
  assessmentComponents          AssessmentComponent[]
  markEntries                   MarkEntry[]
  casRecords                    CasRecord[]
  reportCards                   ReportCard[]
  promotionRecords              PromotionRecord[]
  timetableSlots                TimetableSlot[]
  homeworkAssignments           HomeworkAssignment[]
  homeworkSubmissions           HomeworkSubmission[]
  staffContracts                StaffContract[]
  payrollRuns                   PayrollRun[]
  payrollLines                  PayrollLine[]
  payslips                      Payslip[]
  accountingPeriods             AccountingPeriod[]
  conversations                 Conversation[]
  conversationParticipants      ConversationParticipant[]
  messages                      Message[]
  messageReadReceipts           MessageReadReceipt[]
  libraryBooks                  LibraryBook[]
  libraryCopies                 LibraryCopy[]
  libraryIssues                 LibraryIssue[]
  transportRoutes               TransportRoute[]
  transportStops                TransportStop[]
  transportVehicles             TransportVehicle[]
  transportDriverAssignments    TransportDriverAssignment[]
  transportEnrollments          TransportEnrollment[]
  transportLogs                 TransportLog[]
  schoolCalendarDays            SchoolCalendarDay[]
  staffLeaveBalances            StaffLeaveBalance[]
  staffLeaveRequests            StaffLeaveRequest[]
  syllabusTopics                SyllabusTopic[]
}

model User {
  id               String     @id @default(uuid())
  tenantId         String
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  email            String?
  phone            String?
  passwordHash     String?
  authMethod       AuthMethod @default(PASSWORD)
  status           UserStatus @default(PENDING)
  lastLoginAt      DateTime?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())

  userRoles                   UserRole[]
  refreshTokens               RefreshToken[]
  otpCodes                    OtpCode[]
  auditLogs                   AuditLog[]
  student                     Student?               @relation("StudentUser")
  staff                       Staff?                 @relation("StaffUser")
  guardian                    Guardian?              @relation("GuardianUser")
  submittedAttendanceSessions AttendanceSession[]    @relation("SubmittedAttendanceSessions")
  approvedStaffAttendance     StaffAttendance[]      @relation("ApprovedStaffAttendance")
  collectedPayments           Payment[]              @relation("CollectedPayments")
  cashierCloseCollectorScopes CashierClose[]         @relation("CashierCloseCollector")
  closedCashierCloses         CashierClose[]         @relation("ClosedCashierCloses")
  createdPaymentRefunds       PaymentRefund[]        @relation("CreatedPaymentRefunds")
  journalEntries              JournalEntry[]         @relation("CreatedJournalEntries")
  createdNotices              Notice[]               @relation("CreatedNotices")
  createdEvents               Event[]                @relation("CreatedEvents")
  approvedWaivers             FeeWaiver[]            @relation("ApprovedFeeWaivers")
  createdActivityPosts        ActivityPost[]         @relation("CreatedActivityPosts")
  notificationDeliveries      NotificationDelivery[] @relation("NotificationActor")
  enteredMarks                MarkEntry[]            @relation("EnteredMarks")
  reviewedStaffLeaveRequests  StaffLeaveRequest[]    @relation("ReviewedStaffLeaveRequests")
  requestedMarkLockRequests   MarkLockRequest[]      @relation("RequestedMarkLock")
  reviewedMarkLockRequests    MarkLockRequest[]      @relation("ReviewedMarkLock")

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name        String
  description String?
  isSystem    Boolean @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
}

model UserRole {
  id           String   @id @default(uuid())
  userId       String
  roleId       String
  tenantId     String
  scopeId      String?
  assignedById String?
  assignedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  tenantId   String
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AcademicYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  startsOn  DateTime
  endsOn    DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  enrollments           Enrollment[]
  attendanceSessions    AttendanceSession[]
  feePlans              FeePlan[]
  studentFeeAssignments StudentFeeAssignment[]
  invoices              Invoice[]
  feeBillingRuns        FeeBillingRun[]
  feeDueSchedules       FeeDueSchedule[]
  teacherAssignments    SubjectTeacherAssignment[]
  examTerms             ExamTerm[]
  casRecords            CasRecord[]
  reportCards           ReportCard[]
  examTimetableSlots    ExamTimetableSlot[]
  promotionRecords      PromotionRecord[]
  timetableSlots        TimetableSlot[]
  homeworkAssignments   HomeworkAssignment[]

  @@unique([tenantId, name])
}

model Class {
  id       String @id @default(uuid())
  tenantId String
  name     String
  level    Int

  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  students                Student[]
  subjects                Subject[]
  sections                Section[]
  enrollments             Enrollment[]
  attendanceSessions      AttendanceSession[]
  feePlans                FeePlan[]
  notices                 Notice[]
  events                  Event[]
  discountRules           DiscountRule[]
  activityPosts           ActivityPost[]
  moodLogs                MoodLog[]
  developmentalMilestones DevelopmentalMilestone[]
  teacherAssignments      SubjectTeacherAssignment[]
  casRecords              CasRecord[]
  reportCards             ReportCard[]
  promotionRecordsFrom    PromotionRecord[]          @relation("PromotionFromClass")
  promotionRecordsTo      PromotionRecord[]          @relation("PromotionToClass")
  timetableSlots          TimetableSlot[]
  homeworkAssignments     HomeworkAssignment[]
  conversations           Conversation[]
  examTimetableSlots      ExamTimetableSlot[]

  @@unique([tenantId, name])
}

model Section {
  id        String   @id @default(uuid())
  tenantId  String
  classId   String
  name      String
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class                   Class                      @relation(fields: [classId], references: [id], onDelete: Restrict)
  students                Student[]
  enrollments             Enrollment[]
  attendanceSessions      AttendanceSession[]
  notices                 Notice[]
  events                  Event[]
  activityPosts           ActivityPost[]
  moodLogs                MoodLog[]
  developmentalMilestones DevelopmentalMilestone[]
  teacherAssignments      SubjectTeacherAssignment[]
  casRecords              CasRecord[]
  reportCards             ReportCard[]
  promotionRecordsFrom    PromotionRecord[]          @relation("PromotionFromSection")
  promotionRecordsTo      PromotionRecord[]          @relation("PromotionToSection")
  timetableSlots          TimetableSlot[]
  homeworkAssignments     HomeworkAssignment[]
  conversations           Conversation[]
  examTimetableSlots      ExamTimetableSlot[]

  @@unique([tenantId, classId, name])
}

model Subject {
  id             String  @id @default(uuid())
  tenantId       String
  classId        String
  name           String
  code           String
  type           String
  hasPractical   Boolean @default(false)
  theoryMarks    Float?
  practicalMarks Float?
  passMarks      Float?

  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class                Class                      @relation(fields: [classId], references: [id], onDelete: Restrict)
  teacherAssignments   SubjectTeacherAssignment[]
  assessmentComponents AssessmentComponent[]
  markEntries          MarkEntry[]
  casRecords           CasRecord[]
  timetableSlots       TimetableSlot[]
  homeworkAssignments  HomeworkAssignment[]
  examTimetableSlots   ExamTimetableSlot[]
  syllabusTopics       SyllabusTopic[]

  @@unique([tenantId, classId, code])
}

model Student {
  id                        String                 @id @default(uuid())
  tenantId                  String
  userId                    String?                @unique
  studentSystemId           String
  firstNameEn               String
  lastNameEn                String
  firstNameNp               String?
  lastNameNp                String?
  dateOfBirth               DateTime
  gender                    Gender
  bloodGroup                String?
  nationality               String                 @default("Nepali")
  religion                  String?
  ethnicity                 String?
  motherTongue              String?
  disabilityFlag            String?
  nationalStudentId         String?
  birthCertNumber           String?
  citizenshipNo             String?
  photoUrl                  String?
  admissionDate             DateTime
  admissionNumber           String?
  previousSchool            String?
  transferCertUrl           String?
  lifecycleStatus           StudentLifecycleStatus @default(ACTIVE)
  exitReason                String?
  exitedAt                  DateTime?
  destinationSchool         String?
  conductRemark             String?
  feeClearanceWaivedAt      DateTime?
  feeClearanceWaivedById    String?
  mediumOfInstruct          String                 @default("English")
  classId                   String
  sectionId                 String?
  section                   String?
  rollNumber                Int?
  medicalConditions         String?
  severeAllergies           String?
  medications               String?
  specialNeeds              String?
  emergencyName             String?
  emergencyPhone            String?
  doctorName                String?
  doctorPhone               String?
  privacyConsentAt          DateTime?
  dataProcessingConsentedAt DateTime?
  medicalConsentAt          DateTime?
  photoUsageConsentAt       DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  tenant                   Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user                     User?                        @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  class                    Class                        @relation(fields: [classId], references: [id], onDelete: Restrict)
  sectionRef               Section?                     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  guardianLinks            StudentGuardian[]
  enrollments              Enrollment[]
  attendanceRecords        AttendanceRecord[]
  studentFeeAssignments    StudentFeeAssignment[]
  invoices                 Invoice[]
  payments                 Payment[]
  documents                StudentDocument[]
  generatedDocuments       GeneratedStudentDocument[]
  lifecycleTransitions     StudentLifecycleTransition[]
  siblingMemberships       SiblingGroupMember[]
  activityTags             ActivityPostStudent[]
  activityReactions        ActivityReaction[]
  developmentalMilestones  DevelopmentalMilestone[]
  moodLogs                 MoodLog[]
  feeWaivers               FeeWaiver[]
  notificationDeliveries   NotificationDelivery[]
  markEntries              MarkEntry[]
  casRecords               CasRecord[]
  reportCards              ReportCard[]
  promotionRecords         PromotionRecord[]
  homeworkSubmissions      HomeworkSubmission[]
  conversations            Conversation[]
  conversationParticipants ConversationParticipant[]
  libraryIssues            LibraryIssue[]
  transportEnrollments     TransportEnrollment[]
  transportLogs            TransportLog[]

  @@unique([tenantId, studentSystemId])
  @@index([tenantId, classId, sectionId])
}

model Guardian {
  id               String    @id @default(uuid())
  tenantId         String
  userId           String?   @unique
  fullName         String
  relation         String
  primaryPhone     String
  secondaryPhone   String?
  email            String?
  occupation       String?
  homeAddress      String?
  wardNumber       String?
  receivesAlerts   Boolean   @default(false)
  privacyConsentAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant                   Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user                     User?                          @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  studentLinks             StudentGuardian[]
  consents                 GuardianConsent[]
  notificationDeliveries   NotificationDelivery[]
  activityReactions        ActivityReaction[]
  conversations            Conversation[]
  conversationParticipants ConversationParticipant[]
  messages                 Message[]
  messageReadReceipts      MessageReadReceipt[]
  identityVerifications    GuardianIdentityVerification[]

  @@unique([tenantId, primaryPhone])
}

model GuardianIdentityVerification {
  id                 String                             @id @default(uuid())
  tenantId           String
  guardianId         String
  status             GuardianIdentityVerificationStatus @default(PENDING)
  documentType       String
  documentNumber     String?
  evidenceDocumentId String?
  notes              String?
  submittedById      String?
  reviewedById       String?
  reviewedAt         DateTime?
  reviewNote         String?
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([tenantId, guardianId, status])
  @@index([tenantId, status, createdAt])
}

model StudentGuardian {
  id             String   @id @default(uuid())
  tenantId       String
  studentId      String
  guardianId     String
  relation       String
  isPrimary      Boolean  @default(false)
  appLoginLinked Boolean  @default(false)
  createdAt      DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
}

model Enrollment {
  id                  String           @id @default(uuid())
  tenantId            String
  studentId           String
  academicYearId      String
  classId             String
  sectionId           String?
  rollNumber          Int?
  admissionNumber     String?
  admissionDate       DateTime
  mediumOfInstruction String
  status              EnrollmentStatus @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@unique([tenantId, studentId, academicYearId])
}

model Staff {
  id                String       @id @default(uuid())
  tenantId          String
  userId            String       @unique
  employeeId        String       @unique
  firstName         String
  lastName          String
  firstNameNp       String?
  lastNameNp        String?
  photoUrl          String?
  dateOfBirth       DateTime
  gender            Gender
  address           String
  teacherRegistryId String?
  citizenshipNo     String?
  panNumber         String?
  bankAccount       String?
  bankName          String?
  qualifications    String?
  experience        String?
  joiningDate       DateTime
  contractType      ContractType
  probationEndDate  DateTime?
  privacyConsentAt  DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user                       User                        @relation("StaffUser", fields: [userId], references: [id], onDelete: Cascade)
  attendanceRecords          StaffAttendance[]
  teacherAssignments         SubjectTeacherAssignment[]
  timetableSlots             TimetableSlot[]
  homeworkAssignments        HomeworkAssignment[]
  staffContracts             StaffContract[]
  payrollLines               PayrollLine[]
  payslips                   Payslip[]
  conversationParticipants   ConversationParticipant[]
  messages                   Message[]
  libraryIssues              LibraryIssue[]
  transportDriverAssignments TransportDriverAssignment[]
  leaveBalances              StaffLeaveBalance[]
  leaveRequests              StaffLeaveRequest[]
  syllabusTopics             SyllabusTopic[]
}

model AttendanceSession {
  id             String                   @id @default(uuid())
  tenantId       String
  academicYearId String
  classId        String
  sectionId      String?
  attendanceDate DateTime
  submittedById  String?
  submittedAt    DateTime?
  lockAt         DateTime
  conflictStatus AttendanceConflictStatus @default(NONE)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class        Class                @relation(fields: [classId], references: [id], onDelete: Restrict)
  section      Section?             @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  submittedBy  User?                @relation("SubmittedAttendanceSessions", fields: [submittedById], references: [id], onDelete: SetNull)
  records      AttendanceRecord[]
  conflicts    AttendanceConflict[]

  @@unique([tenantId, attendanceDate, classId, sectionId])
}

model AttendanceRecord {
  id                  String           @id @default(uuid())
  tenantId            String
  attendanceSessionId String
  studentId           String
  status              AttendanceStatus @default(PRESENT)
  remark              String?
  lateAt              DateTime?
  createdAt           DateTime         @default(now())

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
