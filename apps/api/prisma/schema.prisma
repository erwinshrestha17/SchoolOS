  logs        TransportLog[]

  @@unique([tenantId, routeId, sequence])
  @@index([tenantId, routeId])
}

model TransportVehicle {
  id                    String                 @id @default(uuid())
  tenantId              String
  registrationNumber    String
  capacity              Int
  status                TransportVehicleStatus @default(ACTIVE)
  fitnessCertificateExp DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignments TransportDriverAssignment[]
  logs        TransportLog[]
  routes      TransportRoute[]

  @@unique([tenantId, registrationNumber])
  @@index([tenantId, status])
}

model TransportDriverAssignment {
  id             String    @id @default(uuid())
  tenantId       String
  vehicleId      String
  staffId        String
  licenseNumber  String?
  licenseExpires DateTime?
  startsAt       DateTime
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicle TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  staff   Staff            @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([tenantId, vehicleId, startsAt])
  @@index([tenantId, staffId])
}

model TransportEnrollment {
  id              String                    @id @default(uuid())
  tenantId        String
  studentId       String
  routeId         String
  stopId          String
  feeAmount       Decimal                   @default(0) @db.Decimal(12, 2)
  status          TransportEnrollmentStatus @default(ACTIVE)
  startedAt       DateTime                  @default(now())
  endedAt         DateTime?
  feeAssignmentId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student       Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route         TransportRoute        @relation(fields: [routeId], references: [id], onDelete: Restrict)
  stop          TransportStop         @relation(fields: [stopId], references: [id], onDelete: Restrict)
  feeAssignment StudentFeeAssignment? @relation(fields: [feeAssignmentId], references: [id], onDelete: SetNull)
  logs          TransportLog[]

  @@index([tenantId, routeId, stopId, status])
  @@index([tenantId, studentId, status])
}

model TransportLog {
  id           String                  @id @default(uuid())
  tenantId     String
  routeId      String
  stopId       String?
  vehicleId    String?
  enrollmentId String?
  studentId    String?
  status       TransportBoardingStatus
  occurredAt   DateTime                @default(now())
  note         String?
  createdById  String?
  createdAt    DateTime                @default(now())

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  route      TransportRoute       @relation(fields: [routeId], references: [id], onDelete: Restrict)
  stop       TransportStop?       @relation(fields: [stopId], references: [id], onDelete: SetNull)
  vehicle    TransportVehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  enrollment TransportEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  student    Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([tenantId, routeId, occurredAt])
  @@index([tenantId, studentId, occurredAt])
}
