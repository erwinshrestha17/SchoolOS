  heading            Decimal? @db.Decimal(8, 2)
  recordedAt         DateTime @default(now())
  createdAt          DateTime @default(now())

  tenant           Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  trip             TransportTrip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vehicle          TransportVehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverAssignment TransportDriverAssignment? @relation(fields: [driverAssignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, tripId, recordedAt])
  @@index([tenantId, vehicleId, recordedAt])
}

model CanteenMenuItem {
