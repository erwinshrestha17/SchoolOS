  resolvedAt        DateTime?
  resolvedByUserId  String?

  thread ParentTeacherThread @relation(fields: [threadId], references: [id], onDelete: Restrict)

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, status, createdAt])
}

model ChatAbuseReport {
  id               String                @id @default(uuid())
  tenantId         String
  threadId         String
  messageId        String?
  reportedByUserId String
  reason           String
  status           ChatAbuseReportStatus @default(OPEN)
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime              @default(now())

  thread  ParentTeacherThread   @relation(fields: [threadId], references: [id], onDelete: Restrict)
  message ParentTeacherMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, status, createdAt])
}

model LibraryBook {
