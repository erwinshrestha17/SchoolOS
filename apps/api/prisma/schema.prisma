  lowBalanceThreshold Decimal  @default(100) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
