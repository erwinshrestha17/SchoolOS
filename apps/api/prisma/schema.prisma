  closedByUserId String?
  closeReason    String?

  messages     ParentTeacherMessage[]
  escalations  ChatEscalation[]
  abuseReports ChatAbuseReport[]

  @@index([tenantId, studentId, academicYearId])
  @@index([tenantId, guardianId])
  @@index([tenantId, classTeacherId])
  @@index([tenantId, status, updatedAt])
}

model ParentTeacherMessage {
  id           String                       @id @default(uuid())
  tenantId     String
  threadId     String
  senderUserId String
  senderRole   ParentTeacherSenderRole
  message      String
  priority     ParentTeacherMessagePriority @default(NORMAL)
  status       MessageStatus                @default(SENT)
  sentAt       DateTime                     @default(now())
  deliveredAt  DateTime?
  readAt       DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  thread       ParentTeacherThread @relation(fields: [threadId], references: [id], onDelete: Restrict)
  abuseReports ChatAbuseReport[]

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, status, updatedAt])
}

model ChatAvailabilityRule {
  id            String                        @id @default(uuid())
  tenantId      String
