  updatedAt     DateTime                      @updatedAt

  @@unique([tenantId, dayOfWeek, appliesToRole])
  @@index([tenantId, dayOfWeek])
}

model ChatEscalation {
  id                String               @id @default(uuid())
  tenantId          String
  threadId          String
  escalatedByUserId String
  escalatedToUserId String?
  reason            String
  status            ChatEscalationStatus @default(OPEN)
