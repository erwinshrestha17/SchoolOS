model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  mode      Mode     @default(SINGLE)
  plan      String   @default("free")
  panNumber String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users                         User[]
  roles                         Role[]
  classes                       Class[]
  students                      Student[]
  subjects                      Subject[]
  staff                         Staff[]
  academicYears                 AcademicYear[]
  sections                      Section[]
  guardians                     Guardian[]
  studentGuardians              StudentGuardian[]
  enrollments                   Enrollment[]
  attendanceSessions            AttendanceSession[]
  attendanceRecords             AttendanceRecord[]
  staffAttendance               StaffAttendance[]
  feeHeads                      FeeHead[]
  feePlans                      FeePlan[]
  feePlanItems                  FeePlanItem[]
  studentFeeAssignments         StudentFeeAssignment[]
  invoices                      Invoice[]
  invoiceLines                  InvoiceLine[]
  payments                      Payment[]
  paymentRefunds                PaymentRefund[]
  cashierCloses                 CashierClose[]
  receipts                      Receipt[]
  receiptReprintHistory         ReceiptReprintHistory[]
  chartAccounts                 ChartAccount[]
  journalEntries                JournalEntry[]
  journalLines                  JournalLine[]
  notices                       Notice[]
  events                        Event[]
  studentDocuments              StudentDocument[]
  siblingGroups                 SiblingGroup[]
  siblingGroupMembers           SiblingGroupMember[]
  attendanceConflicts           AttendanceConflict[]
  feeBillingRuns                FeeBillingRun[]
  feeDueSchedules               FeeDueSchedule[]
  discountRules                 DiscountRule[]
  feeWaivers                    FeeWaiver[]
  activityPosts                 ActivityPost[]
  activityAttachments           ActivityAttachment[]
  activityPostStudents          ActivityPostStudent[]
  activityReactions             ActivityReaction[]
  developmentalMilestones       DevelopmentalMilestone[]
  moodLogs                      MoodLog[]
  notificationDeliveries        NotificationDelivery[]
  guardianConsents              GuardianConsent[]
  guardianIdentityVerifications GuardianIdentityVerification[]
  generatedStudentDocuments     GeneratedStudentDocument[]
  lifecycleTransitions          StudentLifecycleTransition[]
  attendanceSyncSubmissions     AttendanceSyncSubmission[]
  teacherAssignments            SubjectTeacherAssignment[]
  examTerms                     ExamTerm[]
  examTimetableSlots            ExamTimetableSlot[]
  markLockRequests              MarkLockRequest[]
  assessmentComponents          AssessmentComponent[]
  markEntries                   MarkEntry[]
  casRecords                    CasRecord[]
  reportCards                   ReportCard[]
  promotionRecords              PromotionRecord[]
  timetableSlots                TimetableSlot[]
  timetablePeriods              TimetablePeriod[]
  timetableRooms                Room[]
  timetableVersions             TimetableVersion[]
  teacherAvailabilities         TeacherAvailability[]
  teacherWorkloadLimits         TeacherWorkloadLimit[]
  timetableSubstitutions        TimetableSubstitution[]
  homeworkAssignments           HomeworkAssignment[]
  homeworkSubmissions           HomeworkSubmission[]
  homeworkAttachments           HomeworkAttachment[]
  homeworkReminderBatches       HomeworkReminderBatch[]
  staffContracts                StaffContract[]
  staffQualifications           StaffQualification[]
  staffExperienceRecords        StaffExperienceRecord[]
  payrollRuns                   PayrollRun[]
  payrollLines                  PayrollLine[]
  payslips                      Payslip[]
  salaryStructures              SalaryStructure[]
  salaryComponents              SalaryComponent[]
  accountingPeriods             AccountingPeriod[]
  fiscalYears                   FiscalYear[]
  fiscalPeriods                 FiscalPeriod[]
  conversations                 Conversation[]
  conversationParticipants      ConversationParticipant[]
  messages                      Message[]
  messageReadReceipts           MessageReadReceipt[]
  libraryBooks                  LibraryBook[]
  libraryCopies                 LibraryCopy[]
  libraryIssues                 LibraryIssue[]
  transportRoutes               TransportRoute[]
  transportStops                TransportStop[]
  transportVehicles             TransportVehicle[]
  transportDriverAssignments    TransportDriverAssignment[]
  transportEnrollments          TransportEnrollment[]
  transportLogs                 TransportLog[]
  transportStudentAssignments   TransportStudentAssignment[]
  transportTrips                TransportTrip[]
  transportTripStudentStatuses  TransportTripStudentStatus[]
  transportLocationPings        TransportLocationPing[]
  canteenMenuItems              CanteenMenuItem[]
  canteenMealPlans              CanteenMealPlan[]
  canteenStudentEnrollments     CanteenStudentEnrollment[]
  canteenMealServings           CanteenMealServing[]
  canteenWallets                CanteenWallet[]
  canteenWalletTransactions     CanteenWalletTransaction[]
  canteenPosSales               CanteenPosSale[]
  canteenPosSaleItems           CanteenPosSaleItem[]
  canteenSpendingControls       CanteenSpendingControl[]
  schoolCalendarDays            SchoolCalendarDay[]
  staffLeaveBalances            StaffLeaveBalance[]
  staffLeaveRequests            StaffLeaveRequest[]
  syllabusTopics                SyllabusTopic[]
  settings                      TenantSetting[]
  fileAssets                    FileAsset[]
  studentMergeHistory           StudentMergeHistory[]
  studentIdentities             StudentIdentity[]
  studentDocumentHistory        StudentDocumentHistory[]
  attendanceCorrectionRequests   AttendanceCorrectionRequest[]
}

model User {
  id               String      @id @default(uuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  email            String?
  phone            String?
  passwordHash     String?
  authMethod       AuthMethod  @default(PASSWORD)
  status           UserStatus  @default(PENDING)
  lastLoginAt      DateTime?
  failedLoginCount Int         @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime    @default(now())
  fileAssets       FileAsset[]

  userRoles                   UserRole[]
  refreshTokens               RefreshToken[]
  otpCodes                    OtpCode[]
  auditLogs                   AuditLog[]
  student                     Student?                     @relation("StudentUser")
  staff                       Staff?                       @relation("StaffUser")
  guardian                    Guardian?                    @relation("GuardianUser")
  submittedAttendanceSessions AttendanceSession[]          @relation("SubmittedAttendanceSessions")
  approvedStaffAttendance     StaffAttendance[]            @relation("ApprovedStaffAttendance")
  collectedPayments           Payment[]                    @relation("CollectedPayments")
  cashierCloseCollectorScopes CashierClose[]               @relation("CashierCloseCollector")
  closedCashierCloses         CashierClose[]               @relation("ClosedCashierCloses")
  createdPaymentRefunds       PaymentRefund[]              @relation("CreatedPaymentRefunds")
  journalEntries              JournalEntry[]               @relation("CreatedJournalEntries")
  createdNotices              Notice[]                     @relation("CreatedNotices")
  createdEvents               Event[]                      @relation("CreatedEvents")
  approvedWaivers             FeeWaiver[]                  @relation("ApprovedFeeWaivers")
  createdActivityPosts        ActivityPost[]               @relation("CreatedActivityPosts")
  notificationDeliveries      NotificationDelivery[]       @relation("NotificationActor")
  enteredMarks                MarkEntry[]                  @relation("EnteredMarks")
  reviewedStaffLeaveRequests  StaffLeaveRequest[]          @relation("ReviewedStaffLeaveRequests")
  requestedMarkLockRequests   MarkLockRequest[]            @relation("RequestedMarkLock")
  reviewedMarkLockRequests    MarkLockRequest[]            @relation("ReviewedMarkLock")
  publishedReportCards        ReportCard[]                 @relation("PublishedReportCards")
  transportTripsCreated       TransportTrip[]              @relation("TransportTripCreatedBy")
  transportTripsCompleted     TransportTrip[]              @relation("TransportTripCompletedBy")
  transportStatusesMarked     TransportTripStudentStatus[] @relation("TransportTripStatusMarkedBy")
  canteenMealServingsServed   CanteenMealServing[]         @relation("CanteenMealServedBy")
  canteenWalletTransactions   CanteenWalletTransaction[]   @relation("CanteenWalletTransactionCreatedBy")
  canteenPosSalesCreated      CanteenPosSale[]             @relation("CanteenPosSaleCreatedBy")
  reprintedReceipts           ReceiptReprintHistory[]      @relation("ReceiptReprinter")
  reversedPayments            Payment[]                    @relation("ReversedPayments")
  mergedStudents              StudentMergeHistory[]        @relation("MergedBy")

  requestedAttendanceCorrections AttendanceCorrectionRequest[] @relation("RequestedAttendanceCorrections")
  reviewedAttendanceCorrections  AttendanceCorrectionRequest[] @relation("ReviewedAttendanceCorrections")

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name        String
  description String?
  isSystem    Boolean @default(false)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
}

model UserRole {
  id           String   @id @default(uuid())
  userId       String
  roleId       String
  tenantId     String
  scopeId      String?
  assignedById String?
  assignedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  tenantId   String
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model FileAsset {
  id               String     @id @default(uuid())
  tenantId         String
  uploadedByUserId String?
  originalFilename String
  objectKey        String     @unique
  mimeType         String
  sizeBytes        BigInt
  module           String?
  entityId         String?
  status           FileStatus @default(UPLOADED)
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  softDeletedAt    DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploadedBy          User?                @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  activityAttachments ActivityAttachment[]
  homeworkAttachments HomeworkAttachment[]
  studentPhoto        Student?             @relation("StudentPhoto")
  studentDocuments    StudentDocument[]    @relation("DocumentFile")

  @@index([tenantId, module, entityId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  startsOn  DateTime
  endsOn    DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  enrollments           Enrollment[]
  attendanceSessions    AttendanceSession[]
  feePlans              FeePlan[]
  studentFeeAssignments StudentFeeAssignment[]
  invoices              Invoice[]
  feeBillingRuns        FeeBillingRun[]
  feeDueSchedules       FeeDueSchedule[]
  teacherAssignments    SubjectTeacherAssignment[]
  examTerms             ExamTerm[]
  casRecords            CasRecord[]
  reportCards           ReportCard[]
  examTimetableSlots    ExamTimetableSlot[]
  promotionRecords      PromotionRecord[]
  timetableSlots        TimetableSlot[]
  timetablePeriods      TimetablePeriod[]
  timetableVersions     TimetableVersion[]
  homeworkAssignments   HomeworkAssignment[]

  @@unique([tenantId, name])
}

model Class {
  id       String @id @default(uuid())
  tenantId String
  name     String
  level    Int

  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  students                Student[]
  subjects                Subject[]
  sections                Section[]
  enrollments             Enrollment[]
  attendanceSessions      AttendanceSession[]
  feePlans                FeePlan[]
  notices                 Notice[]
  events                  Event[]
  discountRules           DiscountRule[]
  activityPosts           ActivityPost[]
  moodLogs                MoodLog[]
  developmentalMilestones DevelopmentalMilestone[]
  teacherAssignments      SubjectTeacherAssignment[]
  casRecords              CasRecord[]
  reportCards             ReportCard[]
  promotionRecordsFrom    PromotionRecord[]          @relation("PromotionFromClass")
  promotionRecordsTo      PromotionRecord[]          @relation("PromotionToClass")
  timetableSlots          TimetableSlot[]
  timetableVersions       TimetableVersion[]
  homeworkAssignments     HomeworkAssignment[]
  conversations           Conversation[]
  examTimetableSlots      ExamTimetableSlot[]

  @@unique([tenantId, name])
}

model Section {
  id        String   @id @default(uuid())
  tenantId  String
  classId   String
  name      String
  capacity  Int?
  classTeacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class                   Class                      @relation(fields: [classId], references: [id], onDelete: Restrict)
  classTeacher            Staff?                     @relation("ClassTeacherSections", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students                Student[]
  enrollments             Enrollment[]
  attendanceSessions      AttendanceSession[]
  notices                 Notice[]
  events                  Event[]
  activityPosts           ActivityPost[]
  moodLogs                MoodLog[]
  developmentalMilestones DevelopmentalMilestone[]
  teacherAssignments      SubjectTeacherAssignment[]
  casRecords              CasRecord[]
  reportCards             ReportCard[]
  promotionRecordsFrom    PromotionRecord[]          @relation("PromotionFromSection")
  promotionRecordsTo      PromotionRecord[]          @relation("PromotionToSection")
  timetableSlots          TimetableSlot[]
  timetableVersions       TimetableVersion[]
  homeworkAssignments     HomeworkAssignment[]
  conversations           Conversation[]
  examTimetableSlots      ExamTimetableSlot[]

  @@unique([tenantId, classId, name])
}

model Subject {
  id             String  @id @default(uuid())
  tenantId       String
  classId        String
  name           String
  code           String
  type           String
  hasPractical   Boolean @default(false)
  theoryMarks    Float?
  practicalMarks Float?
  passMarks      Float?

  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  class                Class                      @relation(fields: [classId], references: [id], onDelete: Restrict)
  teacherAssignments   SubjectTeacherAssignment[]
  assessmentComponents AssessmentComponent[]
  markEntries          MarkEntry[]
  casRecords           CasRecord[]
  timetableSlots       TimetableSlot[]
  homeworkAssignments  HomeworkAssignment[]
  examTimetableSlots   ExamTimetableSlot[]
  syllabusTopics       SyllabusTopic[]

  @@unique([tenantId, classId, code])
}

model Student {
  id                        String                 @id @default(uuid())
  tenantId                  String
  userId                    String?                @unique
  studentSystemId           String
  firstNameEn               String
  lastNameEn                String
  firstNameNp               String?
  lastNameNp                String?
  dateOfBirth               DateTime
  gender                    Gender
  bloodGroup                String?
  nationality               String                 @default("Nepali")
  religion                  String?
  ethnicity                 String?
  motherTongue              String?
  disabilityFlag            String?
  nationalStudentId         String?
  birthCertNumber           String?
  citizenshipNo             String?
  photoUrl                  String?
  photoFileId               String?                @unique
  admissionDate             DateTime
  admissionNumber           String?
  previousSchool            String?
  transferCertUrl           String?
  lifecycleStatus           StudentLifecycleStatus @default(ACTIVE)
  exitReason                String?
  exitedAt                  DateTime?
  destinationSchool         String?
