  trips         TransportTrip[]
  locationPings TransportLocationPing[]

  @@index([tenantId, vehicleId, startsAt])
  @@index([tenantId, staffId])
  @@index([tenantId, vehicleId])
  @@index([tenantId, routeId])
}

model TransportEnrollment {
