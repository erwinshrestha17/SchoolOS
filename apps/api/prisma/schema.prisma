  @@index([tenantId, dueAt])
  @@index([tenantId, copyId, status])
}

model TransportRoute {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  vehicleId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicle            TransportVehicle?            @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  stops              TransportStop[]
  enrollments        TransportEnrollment[]
  logs               TransportLog[]
  driverAssignments  TransportDriverAssignment[]
  studentAssignments TransportStudentAssignment[]
  trips              TransportTrip[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, code])
  @@index([tenantId, name])
}

model TransportStop {
  id              String   @id @default(uuid())
  tenantId        String
  routeId         String
  name            String
  sequence        Int
  estimatedPickup String?
  estimatedDrop   String?
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
