model Staff {
  id                       String               @id @default(uuid())
  tenantId                 String
  userId                   String               @unique
  employeeId               String
  staffCode                String?
  firstName                String
  lastName                 String
  firstNameNp              String?
  lastNameNp               String?
  photoUrl                 String?
  dateOfBirth              DateTime
  gender                   Gender
  address                  String
  teacherRegistryId        String?
  citizenshipNo            String?
  panNumber                String?
  bankAccount              String?
  bankName                 String?
  department               String?
  designation              String?
  employmentType           StaffEmploymentType?
  status                   StaffStatus          @default(ACTIVE)
  contractStatus           String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  qualifications           String?
  experience               String?
  joiningDate              DateTime
  contractType             ContractType
  probationEndDate         DateTime?
  privacyConsentAt         DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user                       User                        @relation("StaffUser", fields: [userId], references: [id], onDelete: Cascade)
  attendanceRecords          StaffAttendance[]
  teacherAssignments         SubjectTeacherAssignment[]
  timetableSlots             TimetableSlot[]
  teacherAvailabilities      TeacherAvailability[]
  teacherWorkloadLimits      TeacherWorkloadLimit[]
  timetableSubstitutionsAway TimetableSubstitution[]     @relation("AbsentTeacherSubstitutions")
  timetableSubstitutionsFor  TimetableSubstitution[]     @relation("SubstituteTeacherSubstitutions")
  homeworkAssignments        HomeworkAssignment[]
  staffContracts             StaffContract[]
  salaryStructures           SalaryStructure[]
  payrollLines               PayrollLine[]
  payslips                   Payslip[]
  qualificationsRecords      StaffQualification[]
  experienceRecords          StaffExperienceRecord[]
  conversationParticipants   ConversationParticipant[]
  messages                   Message[]
  libraryIssues              LibraryIssue[]
  transportDriverAssignments TransportDriverAssignment[]
  canteenPosSales            CanteenPosSale[]
  leaveBalances              StaffLeaveBalance[]
  leaveRequests              StaffLeaveRequest[]
  syllabusTopics             SyllabusTopic[]
  classTeacherSections       Section[]                   @relation("ClassTeacherSections")
  documents                  StaffDocument[]
  lifecycleEvents            StaffLifecycleEvent[]

  @@unique([tenantId, employeeId])
  @@unique([tenantId, staffCode])
  @@index([tenantId, status])
  @@index([tenantId, department])
}

model StaffQualification {
  id          String   @id @default(uuid())
  tenantId    String
  staffId     String
  degree      String
  institution String?
  year        Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId])
}

model StaffDocument {
  id           String                @id @default(uuid())
  tenantId     String
  staffId      String
  kind         StaffDocumentKind
  fileId       String                @unique
  name         String
  status       StudentDocumentStatus @default(ACTIVE)
  verifiedById String?
  verifiedAt   DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff      Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  verifiedBy User?  @relation("VerifiedStaffDocuments", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([tenantId, staffId])
}

model StaffLifecycleEvent {
  id          String                  @id @default(uuid())
  tenantId    String
  staffId     String
  eventType   StaffLifecycleEventType
  eventDate   DateTime
  reason      String?
  metadata    Json?
  notes       String?
  createdById String?
  createdAt   DateTime                @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CreatedStaffLifecycleEvents", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, staffId])
}

model StaffExperienceRecord {
  id           String    @id @default(uuid())
  tenantId     String
  staffId      String
  organization String
  role         String?
  startsOn     DateTime?
  endsOn       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId])
}

model StaffContract {
  id             String    @id @default(uuid())
  tenantId       String
  staffId        String
  contractNumber String
  position       String
  startDate      DateTime
  endDate        DateTime?
  baseSalary     Decimal   @db.Decimal(12, 2)
  allowances     Decimal   @default(0) @db.Decimal(12, 2)
  deductions     Decimal   @default(0) @db.Decimal(12, 2)
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff        Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  payrollLines PayrollLine[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId, staffId, status])
}
