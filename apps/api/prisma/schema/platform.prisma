model PlatformPlan {
  id           String             @id @default(uuid())
  key          String             @unique
  name         String
  description  String?
  status       PlatformPlanStatus @default(ACTIVE)
  priceNpr     Decimal            @default(0) @db.Decimal(12, 2)
  billingCycle String             @default("ANNUAL")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  features      PlatformPlanFeature[]
  usageLimits   UsageLimit[]
  subscriptions TenantSubscription[]
  saasInvoices  SaaSInvoice[]
}

model PlatformPlanFeature {
  id         String   @id @default(uuid())
  planId     String
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  plan PlatformPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model TenantSubscription {
  id          String                   @id @default(uuid())
  tenantId    String
  planId      String
  status      TenantSubscriptionStatus @default(TRIAL)
  startsAt    DateTime                 @default(now())
  endsAt      DateTime?
  renewsAt    DateTime?
  trialEndsAt DateTime?
  notes       String?
  addOns      String[]                 @default([])
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan         PlatformPlan  @relation(fields: [planId], references: [id], onDelete: Restrict)
  saasInvoices SaaSInvoice[]

  @@index([tenantId, status])
  @@index([planId])
}

model TenantFeatureOverride {
  id         String   @id @default(uuid())
  tenantId   String
  featureKey String
  enabled    Boolean
  reason     String
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([featureKey])
}

model UsageLimit {
  id        String      @id @default(uuid())
  planId    String
  usageKey  String
  limit     Int
  period    UsagePeriod @default(MONTHLY)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  plan PlatformPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, usageKey, period])
}

model UsageCounter {
  id          String      @id @default(uuid())
  tenantId    String
  usageKey    String
  period      UsagePeriod @default(MONTHLY)
  periodStart DateTime
  value       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usageKey, period, periodStart])
  @@index([tenantId, usageKey])
}

model TenantBillingProfile {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  billingContactName    String?
  billingEmail          String?
  billingPhone          String?
  billingAddress        String?
  panVatNumber          String?
  preferredBillingCycle String   @default("ANNUAL")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SaaSInvoice {
  id                 String            @id @default(uuid())
  tenantId           String
  invoiceNumber      String            @unique
  planId             String?
  subscriptionId     String?
  amount             Decimal           @db.Decimal(12, 2)
  currency           String            @default("NPR")
  issueDate          DateTime
  dueDate            DateTime
  status             SaaSInvoiceStatus @default(DRAFT)
  notes              String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  createdBy          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan         PlatformPlan?       @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  lines        SaaSInvoiceLine[]
  payments     SaaSPayment[]

  @@index([tenantId, status, issueDate])
  @@index([dueDate, status])
  @@index([invoiceNumber])
}

model SaaSInvoiceLine {
  id          String              @id @default(uuid())
  invoiceId   String
  lineType    SaaSInvoiceLineType
  description String
  quantity    Int                 @default(1)
  unitAmount  Decimal             @db.Decimal(12, 2)
  totalAmount Decimal             @db.Decimal(12, 2)

  invoice SaaSInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model SaaSPayment {
  id          String            @id @default(uuid())
  tenantId    String
  invoiceId   String
  amount      Decimal           @db.Decimal(12, 2)
  paymentDate DateTime
  method      SaaSPaymentMethod
  reference   String?
  notes       String?
  createdBy   String?
  createdAt   DateTime          @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoice SaaSInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([tenantId, paymentDate])
  @@index([invoiceId])
}

model PlatformWebhookEndpoint {
  id                String                        @id @default(uuid())
  ownerType         String
  tenantId          String?
  url               String
  signingSecretHash String
  eventTypes        String[]                      @default([])
  status            PlatformWebhookEndpointStatus @default(ACTIVE)
  createdBy         String?
  disabledAt        DateTime?
  disabledBy        String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  tenant     Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries PlatformWebhookDelivery[]

  @@index([tenantId, status])
  @@index([ownerType, status])
}

model PlatformWebhookDelivery {
  id                     String                        @id @default(uuid())
  endpointId             String
  tenantId               String?
  eventType              String
  payloadChecksum        String
  status                 PlatformWebhookDeliveryStatus @default(PENDING)
  retryCount             Int                           @default(0)
  responseCode           Int?
  responseMessageSummary String?
  createdAt              DateTime                      @default(now())
  lastAttemptAt          DateTime?
  deliveredAt            DateTime?

  endpoint PlatformWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  tenant   Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([endpointId, createdAt])
  @@index([tenantId, eventType, createdAt])
  @@index([status, createdAt])
}

model PlatformApiKey {
  id           String               @id @default(uuid())
  tenantId     String
  name         String
  prefix       String               @unique
  keyHash      String               @unique
  keySuffix    String
  scopes       String[]             @default([])
  status       PlatformApiKeyStatus @default(ACTIVE)
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?
  createdBy    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
}

model DemoRequest {
  id                String   @id @default(uuid())
  schoolName        String
  schoolType        String
  location          String
  studentsCount     String
  branchesCount     String?
  contactName       String
  role              String
  phone             String
  email             String
  preferredContact  String?
  currentSystem     String?
  expectedTimeline  String
  interestedModules String[] @default([])
  message           String?
  internalNotes     String?
  status            String   @default("NEW")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email, createdAt])
  @@index([schoolName])
}

model ReportExport {
  id           String             @id @default(uuid())
  tenantId     String?
  scope        String             @default("tenant")
  reportKey    String
  format       String
  filters      Json
  status       ReportExportStatus @default(COMPLETED)
  fileAssetId  String?
  requestedBy  String?
  errorSummary String?
  createdAt    DateTime           @default(now())
  completedAt  DateTime?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([scope, reportKey])
  @@index([tenantId, reportKey, createdAt])
  @@index([tenantId, requestedBy, createdAt])
  @@index([tenantId, fileAssetId])
}
