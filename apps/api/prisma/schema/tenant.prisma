model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model FileAsset {
  id               String          @id @default(uuid())
  tenantId         String
  uploadedByUserId String?
  originalFilename String
  objectKey        String          @unique
  mimeType         String
  sizeBytes        BigInt
  module           String?
  entityId         String?
  storageProvider  StorageProvider @default(LOCAL)
  bucket           String?
  checksumSha256   String?
  ownerType        String?
  ownerId          String?
  visibility       FileVisibility  @default(PRIVATE)
  status           FileStatus      @default(UPLOADED)
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  softDeletedAt    DateTime?
  deletedAt        DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploadedBy          User?                @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  activityAttachments ActivityAttachment[]
  homeworkAttachments HomeworkAttachment[]
  studentPhoto        Student?             @relation("StudentPhoto")
  studentDocuments    StudentDocument[]    @relation("DocumentFile")
  reportCards         ReportCard[]         @relation("ReportCardFile")
  reportCardHistories ReportCardHistory[]  @relation("ReportCardHistoryFile")
  learningResources   LearningResource[]
  approvalAttachments ApprovalAttachment[]
  generatedDocuments  GeneratedDocument[]
  dataExportJobs      DataExportJob[]

  @@index([tenantId, module, entityId])
  @@index([tenantId, ownerType, ownerId])
}
