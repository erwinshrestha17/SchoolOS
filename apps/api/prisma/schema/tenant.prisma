model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model FileAsset {
  id               String          @id @default(uuid())
  tenantId         String
  uploadedByUserId String?
  originalFilename String
  objectKey        String          @unique
  mimeType         String
  sizeBytes        BigInt
  module           String?
  entityId         String?
  storageProvider  StorageProvider @default(LOCAL)
  bucket           String?
  checksumSha256   String?
  ownerType        String?
  ownerId          String?
  visibility       FileVisibility  @default(PRIVATE)
  status           FileStatus      @default(UPLOADED)
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  softDeletedAt    DateTime?
  deletedAt        DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploadedBy          User?                @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  activityAttachments ActivityAttachment[]
  homeworkAttachments HomeworkAttachment[]
  studentPhoto        Student?             @relation("StudentPhoto")
  studentDocuments    StudentDocument[]    @relation("DocumentFile")
  reportCards         ReportCard[]         @relation("ReportCardFile")
  reportCardHistories ReportCardHistory[]  @relation("ReportCardHistoryFile")
  learningResources   LearningResource[]

  @@index([tenantId, module, entityId])
  @@index([tenantId, ownerType, ownerId])
  @@index([tenantId, storageProvider])
  @@index([tenantId, visibility])
}

model ProviderConfig {
  id               String              @id @default(uuid())
  type             ProviderType
  name             String
  enabled          Boolean             @default(false)
  environment      ProviderEnvironment @default(TEST)
  configEncrypted  Json
  secretKeys       String[]            @default([])
  lastValidatedAt  DateTime?
  validationStatus String?
  updatedBy        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([type, name, environment])
  @@index([type, enabled])
}

model SupportOverride {
  id             String    @id @default(uuid())
  platformUserId String
  tenantId       String
  reason         String
  startsAt       DateTime  @default(now())
  expiresAt      DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  platformUser User   @relation("UserSupportOverrides", fields: [platformUserId], references: [id])
  tenant       Tenant @relation(fields: [tenantId], references: [id])

  @@index([platformUserId, isActive])
  @@index([tenantId, isActive])
  @@index([expiresAt])
}

model TenantOnboardingChecklistOverride {
  id        String   @id @default(uuid())
  tenantId  String
  itemKey   String
  completed Boolean
  reason    String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, itemKey])
}
