model Notice {
  id                 String                @id @default(uuid())
  tenantId           String
  classId            String?
  sectionId          String?
  createdById        String?
  title              String
  body               String
  priority           NoticePriority        @default(NORMAL)
  audienceType       AudienceType          @default(ALL)
  attachmentUrl      String?
  idempotencyKey     String?
  lifecycleStatus    NoticeLifecycleStatus @default(DRAFT)
  approvalRequestId  String?
  scheduledFor       DateTime?
  publishedAt        DateTime?
  expiresAt          DateTime?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  archivedAt         DateTime?
  archivedById       String?
  archiveReason      String?
  archivedFromStatus NoticeLifecycleStatus?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  class      Class?                 @relation(fields: [classId], references: [id])
  section    Section?               @relation(fields: [sectionId], references: [id])
  createdBy  User?                  @relation("CreatedNotices", fields: [createdById], references: [id])
  deliveries NotificationDelivery[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, lifecycleStatus, scheduledFor])
}

model Event {
  id           String       @id @default(uuid())
  tenantId     String
  classId      String?
  sectionId    String?
  createdById  String?
  title        String
  description  String?
  eventType    EventType    @default(GENERAL)
  audienceType AudienceType @default(ALL)
  startsAt     DateTime
  endsAt       DateTime?
  location     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  class      Class?                 @relation(fields: [classId], references: [id])
  section    Section?               @relation(fields: [sectionId], references: [id])
  createdBy  User?                  @relation("CreatedEvents", fields: [createdById], references: [id])
  deliveries NotificationDelivery[]
}

model NotificationDelivery {
  id                String              @id @default(uuid())
  tenantId          String
  channel           NotificationChannel
  status            NotificationStatus  @default(QUEUED)
  sourceType        String
  sourceId          String
  audienceType      AudienceType        @default(ALL)
  recipientUserId   String?
  guardianId        String?
  studentId         String?
  noticeId          String?
  eventId           String?
  activityPostId    String?
  destination       String?
  title             String
  body              String
  errorMessage      String?
  sentAt            DateTime?
  retryCount        Int                 @default(0)
  lastRetryAt       DateTime?
  retryReason       String?
  requestedById     String?
  providerMessageId String?
  failureReason     String?
  failureCode       String?
  deliveredAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime            @default(now())

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recipientUser User?                     @relation("NotificationActor", fields: [recipientUserId], references: [id], onDelete: SetNull)
  guardian      Guardian?                 @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  student       Student?                  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  notice        Notice?                   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  event         Event?                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activityPost  ActivityPost?             @relation(fields: [activityPostId], references: [id], onDelete: Cascade)
  readReceipts  NotificationReadReceipt[]

  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, recipientUserId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, status, channel])
  @@index([tenantId, noticeId, status, createdAt])
  @@index([tenantId, recipientUserId, status, createdAt])
  @@index([tenantId, activityPostId], map: "notification_delivery_activity_post_idx")
}

model NotificationReadReceipt {
  tenantId               String
  notificationDeliveryId String
  userId                 String
  readAt                 DateTime @default(now())

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notificationDelivery NotificationDelivery @relation(fields: [notificationDeliveryId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tenantId, notificationDeliveryId, userId])
  @@index([tenantId, userId, readAt])
  @@index([tenantId, notificationDeliveryId, userId])
}

model MobilePushToken {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String
  installationId String
  tokenHash      String
  tokenEncrypted String
  platform       String
  appVersion     String?
  deviceModel    String?
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tokenHash])
  @@unique([tenantId, userId, installationId])
  @@index([tenantId, userId, lastSeenAt])
}

model NoticeReadReceipt {
  id              String   @id @default(uuid())
  tenantId        String
  noticeId        String
  userId          String
  recipientUserId String?
  guardianId      String?
  studentId       String?
  readAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([tenantId, noticeId, userId])
  @@index([tenantId, noticeId, readAt])
}

model CommunicationTemplate {
  id          String                        @id @default(uuid())
  tenantId    String
  key         String
  category    CommunicationTemplateCategory @default(GENERAL)
  channel     CommunicationTemplateChannel  @default(IN_APP)
  language    String                        @default("en")
  title       String
  body        String
  status      CommunicationTemplateStatus   @default(DRAFT)
  version     Int                           @default(1)
  publishedAt DateTime?
  archivedAt  DateTime?
  createdById String
  updatedById String?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, version])
  @@index([tenantId, status, category])
  @@index([tenantId, key, status])
}

model GuardianConsent {
  id                String      @id @default(uuid())
  tenantId          String
  guardianId        String
  consentType       ConsentType
  granted           Boolean     @default(true)
  version           String
  capturedAt        DateTime    @default(now())
  revokedAt         DateTime?
  consentTemplateId String?
  templateKey       String?
  templateVersion   String?
  metadata          Json?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([tenantId, guardianId, consentType])
}

model ConsentTemplate {
  id            String    @id @default(uuid())
  tenantId      String
  key           String
  consentType   String
  version       String
  title         String
  body          String
  status        String    @default("DRAFT")
  effectiveFrom DateTime?
  publishedAt   DateTime?
  archivedAt    DateTime?
  createdById   String
  updatedById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, key, version])
  @@index([tenantId, consentType, status, effectiveFrom])
}

model CommunicationPreference {
  id                    String    @id @default(uuid())
  tenantId              String
  guardianId            String
  marketingOptOutAt     DateTime?
  marketingOptOutById   String?
  marketingOptOutReason String?
  marketingOptOutSource String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([tenantId, guardianId])
}
