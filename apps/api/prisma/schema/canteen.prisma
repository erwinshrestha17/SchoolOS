model CanteenMenuItem {
  id            String                @id @default(uuid())
  tenantId      String
  name          String
  category      String
  description   String?
  unitPrice     Decimal               @default(0) @db.Decimal(12, 2)
  status        CanteenMenuItemStatus @default(ACTIVE)
  isMealItem    Boolean               @default(false)
  allergenTags  String[]              @default([])
  archivedAt    DateTime?
  archiveReason String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  saleItems CanteenPosSaleItem[]

  @@index([tenantId, name, category])
  @@index([tenantId, status])
}

model CanteenMealPlan {
  id                         String                @id @default(uuid())
  tenantId                   String
  name                       String
  description                String?
  mealType                   String
  price                      Decimal               @default(0) @db.Decimal(12, 2)
  billingFrequency           String                @default("MONTHLY")
  status                     CanteenMealPlanStatus @default(ACTIVE)
  duplicateServingPrevention Boolean               @default(true)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  enrollments CanteenStudentEnrollment[]
  servings    CanteenMealServing[]

  @@index([tenantId, status])
}

model CanteenStudentEnrollment {
  id           String                  @id @default(uuid())
  tenantId     String
  studentId    String
  mealPlanId   String
  feeInvoiceId String?
  feePostedAt  DateTime?
  startsOn     DateTime                @db.Date
  endsOn       DateTime?               @db.Date
  status       CanteenEnrollmentStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student  Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  mealPlan CanteenMealPlan      @relation(fields: [mealPlanId], references: [id], onDelete: Restrict)
  servings CanteenMealServing[]

  @@index([tenantId, studentId])
  @@index([tenantId, mealPlanId, status])
  @@index([tenantId, feeInvoiceId])
}

model CanteenMealServing {
  id             String                   @id @default(uuid())
  tenantId       String
  studentId      String
  enrollmentId   String?
  mealPlanId     String?
  mealType       String
  mealDate       DateTime                 @db.Date
  servedAt       DateTime                 @default(now())
  status         CanteenMealServingStatus @default(SERVED)
  servedByUserId String?
  dietaryWarning String?
  overrideReason String?
  overriddenById String?
  notes          String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enrollment   CanteenStudentEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  mealPlan     CanteenMealPlan?          @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)
  servedBy     User?                     @relation("CanteenMealServedBy", fields: [servedByUserId], references: [id], onDelete: SetNull)
  overriddenBy User?                     @relation("CanteenMealOverriddenBy", fields: [overriddenById], references: [id], onDelete: SetNull)

  @@index([tenantId, mealDate, servedAt])
}

model CanteenWallet {
  id                  String   @id @default(uuid())
  tenantId            String
  studentId           String
  balance             Decimal  @default(0) @db.Decimal(12, 2)
  lowBalanceThreshold Decimal  @default(100) @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student      Student                    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  transactions CanteenWalletTransaction[]
  posSales     CanteenPosSale[]

  @@unique([tenantId, studentId])
  @@index([tenantId, studentId])
}

model CanteenWalletTransaction {
  id              String                         @id @default(uuid())
  tenantId        String
  walletId        String
  studentId       String
  type            CanteenWalletTransactionType
  source          CanteenWalletTransactionSource
  amount          Decimal                        @db.Decimal(12, 2)
  balanceAfter    Decimal                        @db.Decimal(12, 2)
  referenceType   String?
  referenceId     String?
  reversalOfId    String?                        @unique
  correctionOfId  String?                        @unique
  idempotencyKey  String?                        @unique
  reason          String?
  note            String?
  transactionDate DateTime                       @default(now())
  createdByUserId String?
  createdAt       DateTime                       @default(now())

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  wallet       CanteenWallet             @relation(fields: [walletId], references: [id], onDelete: Restrict)
  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  createdBy    User?                     @relation("CanteenWalletTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reversalOf   CanteenWalletTransaction? @relation("WalletTransactionReversal", fields: [reversalOfId], references: [id])
  reversalBy   CanteenWalletTransaction? @relation("WalletTransactionReversal")
  correctionOf CanteenWalletTransaction? @relation("WalletTransactionCorrection", fields: [correctionOfId], references: [id])
  correctionBy CanteenWalletTransaction? @relation("WalletTransactionCorrection")

  @@index([tenantId, walletId])
  @@index([tenantId, transactionDate])
}

model CanteenPosSale {
  id              String               @id @default(uuid())
  tenantId        String
  studentId       String?
  staffId         String?
  walletId        String?
  saleDate        DateTime             @default(now())
  paymentMethod   CanteenPaymentMethod @default(CASH)
  status          CanteenPosSaleStatus @default(DRAFT)
  subtotal        Decimal              @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal              @default(0) @db.Decimal(12, 2)
  receiptNumber   String?              @unique
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdByUserId String?
  notes           String?
  idempotencyKey  String?              @unique
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student   Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)
  staff     Staff?               @relation(fields: [staffId], references: [id], onDelete: SetNull)
  wallet    CanteenWallet?       @relation(fields: [walletId], references: [id], onDelete: SetNull)
  createdBy User?                @relation("CanteenPosSaleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items     CanteenPosSaleItem[]

  @@index([tenantId, saleDate])
  @@index([tenantId, status])
  @@index([tenantId, studentId])
}

model CanteenPosSaleItem {
  id         String   @id @default(uuid())
  tenantId   String
  saleId     String
  menuItemId String
  itemName   String
  category   String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sale     CanteenPosSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  menuItem CanteenMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([tenantId, saleId])
  @@index([tenantId, menuItemId])
}

model CanteenSpendingControl {
  id                  String   @id @default(uuid())
  tenantId            String
  studentId           String
  dailySpendingLimit  Decimal? @db.Decimal(12, 2)
  blockedCategories   String[] @default([])
  blockedMenuItemIds  String[] @default([])
  lowBalanceThreshold Decimal? @db.Decimal(12, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([tenantId, studentId])
  @@index([tenantId, studentId])
}

model CanteenSupplier {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  panNumber   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseBills  CanteenPurchaseBill[]
  inventoryItems CanteenInventoryItem[]

  @@index([tenantId, name])
}

model CanteenInventoryItem {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  sku               String?
  category          String
  unit              String   @default("pcs")
  currentStock      Decimal  @default(0) @db.Decimal(12, 2)
  minStockLevel     Decimal  @default(0) @db.Decimal(12, 2)
  unitCost          Decimal  @default(0) @db.Decimal(12, 2)
  defaultSupplierId String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  defaultSupplier CanteenSupplier?          @relation(fields: [defaultSupplierId], references: [id], onDelete: SetNull)
  stockMovements  CanteenStockMovement[]
  purchaseItems   CanteenPurchaseBillItem[]
  wastageRecords  CanteenWastage[]

  @@unique([tenantId, sku])
  @@index([tenantId, name, category])
}

model CanteenPurchaseBill {
  id              String    @id @default(uuid())
  tenantId        String
  supplierId      String
  billNumber      String
  billDate        DateTime  @db.Date
  totalAmount     Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  netAmount       Decimal   @db.Decimal(12, 2)
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  notes           String?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  supplier  CanteenSupplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User?                     @relation("CanteenPurchaseBillCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items     CanteenPurchaseBillItem[]

  @@unique([tenantId, supplierId, billNumber])
  @@index([tenantId, billDate])
}

model CanteenPurchaseBillItem {
  id              String    @id @default(uuid())
  tenantId        String
  purchaseBillId  String
  inventoryItemId String
  quantity        Decimal   @db.Decimal(12, 2)
  unitCost        Decimal   @db.Decimal(12, 2)
  lineTotal       Decimal   @db.Decimal(12, 2)
  expiryDate      DateTime? @db.Date
  batchNumber     String?
  createdAt       DateTime  @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  purchaseBill  CanteenPurchaseBill  @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  inventoryItem CanteenInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([tenantId, purchaseBillId])
  @@index([tenantId, inventoryItemId])
}

model CanteenStockMovement {
  id              String   @id @default(uuid())
  tenantId        String
  inventoryItemId String
  type            String // IN, OUT, ADJUSTMENT
  quantity        Decimal  @db.Decimal(12, 2)
  balanceAfter    Decimal  @db.Decimal(12, 2)
  referenceType   String? // PURCHASE, SALE, WASTAGE, MANUAL
  referenceId     String?
  reason          String?
  note            String?
  movementDate    DateTime @default(now())
  createdByUserId String?
  createdAt       DateTime @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventoryItem CanteenInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  createdBy     User?                @relation("CanteenStockMovementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, inventoryItemId])
  @@index([tenantId, movementDate])
}

model CanteenWastage {
  id              String   @id @default(uuid())
  tenantId        String
  inventoryItemId String
  quantity        Decimal  @db.Decimal(12, 2)
  unitCost        Decimal  @db.Decimal(12, 2)
  totalCost       Decimal  @db.Decimal(12, 2)
  reason          String
  wastageDate     DateTime @db.Date
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventoryItem CanteenInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  createdBy     User?                @relation("CanteenWastageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, inventoryItemId])
  @@index([tenantId, wastageDate])
}
