model LibraryBook {
  id              String    @id @default(uuid())
  tenantId        String
  title           String
  subtitle        String?
  author          String
  isbn            String?
  publisher       String?
  publishedYear   Int?
  edition         String?
  language        String?
  deweyDecimal    String?
  materialType    String?
  subjectCategory String?
  classLevel      String?
  keywords        Json?
  description     String?
  coverImageUrl   String?
  purchasePrice   Decimal?  @db.Decimal(12, 2)
  archivedAt      DateTime?
  archiveReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  copies       LibraryCopy[]
  reservations LibraryReservation[]

  @@unique([tenantId, isbn])
  @@index([tenantId, title])
  @@index([tenantId, author])
  @@index([tenantId, subjectCategory])
  @@index([tenantId, materialType])
}

model LibraryCopy {
  id                String            @id @default(uuid())
  tenantId          String
  bookId            String
  barcode           String
  qrCode            String?
  status            LibraryCopyStatus @default(AVAILABLE)
  shelfLocation     String?
  acquisitionSource String?
  conditionNote     String?
  replacementCost   Decimal?          @db.Decimal(12, 2)
  purchasedAt       DateTime?
  lastInventoryAt   DateTime?
  archivedAt        DateTime?
  archiveReason     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  book         LibraryBook          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  issues       LibraryIssue[]
  reservations LibraryReservation[]
  history      LibraryCopyHistory[]

  @@unique([tenantId, barcode])
  @@unique([tenantId, qrCode])
  @@index([tenantId, bookId, status])
  @@index([tenantId, barcode])
  @@index([tenantId, qrCode])
  @@index([tenantId, status])
}

model LibraryIssue {
  id                String             @id @default(uuid())
  tenantId          String
  copyId            String
  borrowerStudentId String?
  borrowerStaffId   String?
  issuedAt          DateTime           @default(now())
  dueAt             DateTime
  returnedAt        DateTime?
  returnCondition   String?
  status            LibraryIssueStatus @default(ISSUED)
  fineAmount        Decimal            @default(0) @db.Decimal(12, 2)
  invoiceId         String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  copy            LibraryCopy   @relation(fields: [copyId], references: [id], onDelete: Restrict)
  borrowerStudent Student?      @relation(fields: [borrowerStudentId], references: [id], onDelete: SetNull)
  borrowerStaff   Staff?        @relation(fields: [borrowerStaffId], references: [id], onDelete: SetNull)
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  fines           LibraryFine[]

  @@index([tenantId, status, dueAt])
  @@index([tenantId, borrowerStudentId])
  @@index([tenantId, borrowerStaffId])
  @@index([tenantId, dueAt])
  @@index([tenantId, copyId, status])
}

model LibraryFine {
  id               String            @id @default(uuid())
  tenantId         String
  issueId          String
  amount           Decimal           @db.Decimal(12, 2)
  waivedAmount     Decimal           @default(0) @db.Decimal(12, 2)
  status           LibraryFineStatus @default(PENDING)
  feeInvoiceId     String?
  feePostedAt      DateTime?
  waiverReason     String?
  correctionReason String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  issue  LibraryIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, issueId])
  @@index([tenantId, feeInvoiceId])
}

model LibraryReservation {
  id                String    @id @default(uuid())
  tenantId          String
  bookId            String
  copyId            String?
  borrowerStudentId String?
  borrowerStaffId   String?
  status            String    @default("ACTIVE")
  reservedAt        DateTime  @default(now())
  expiresAt         DateTime
  fulfilledIssueId  String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  book   LibraryBook  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  copy   LibraryCopy? @relation(fields: [copyId], references: [id], onDelete: SetNull)

  @@index([tenantId, bookId, status, expiresAt])
  @@index([tenantId, copyId, status])
  @@index([tenantId, borrowerStudentId, status])
  @@index([tenantId, borrowerStaffId, status])
}

model LibraryCopyHistory {
  id           String   @id @default(uuid())
  tenantId     String
  copyId       String
  eventType    String
  statusBefore String?
  statusAfter  String?
  reason       String?
  actorUserId  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  copy   LibraryCopy @relation(fields: [copyId], references: [id], onDelete: Cascade)

  @@index([tenantId, copyId, createdAt])
  @@index([tenantId, eventType, createdAt])
}

model LibrarySetting {
  id                       String   @id @default(uuid())
  tenantId                 String   @unique
  finePerDay               Decimal  @default(0) @db.Decimal(12, 2)
  maxFineAmount            Decimal? @db.Decimal(12, 2)
  gracePeriodDays          Int      @default(0)
  lostBookChargeMultiplier Decimal  @default(1) @db.Decimal(12, 2)
  maxBooksPerStudent       Int      @default(3)
  maxBooksPerStaff         Int      @default(5)
  studentLoanDays          Int      @default(14)
  staffLoanDays            Int      @default(30)
  includeHolidaysInFine    Boolean  @default(false)
  reservationHoldDays      Int      @default(3)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}
