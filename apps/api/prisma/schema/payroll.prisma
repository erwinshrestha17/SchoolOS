model SalaryStructure {
  id            String                @id @default(uuid())
  tenantId      String
  staffId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  basicSalary   Decimal               @db.Decimal(12, 2)
  allowances    Decimal               @default(0) @db.Decimal(12, 2)
  deductions    Decimal               @default(0) @db.Decimal(12, 2)
  pfEnabled     Boolean               @default(false)
  tdsEnabled    Boolean               @default(false)
  paymentMethod PaymentMethod         @default(BANK)
  bankAccount   String?
  bankName      String?
  status        SalaryStructureStatus @default(DRAFT)
  notes         String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  staff        Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  components   SalaryComponent[]
  payrollLines PayrollLine[]

  @@index([tenantId, staffId, status])
  @@index([tenantId, effectiveFrom, effectiveTo])
}

model SalaryComponent {
  id                String              @id @default(uuid())
  tenantId          String
  salaryStructureId String
  name              String
  componentType     SalaryComponentType
  amount            Decimal             @db.Decimal(12, 2)
  taxable           Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  @@index([tenantId, salaryStructureId])
}

model PayrollRun {
  id                         String           @id @default(uuid())
  tenantId                   String
  fiscalYearId               String?
  periodMonth                Int
  periodYear                 Int
  periodStart                DateTime?
  periodEnd                  DateTime?
  status                     PayrollRunStatus @default(DRAFT)
  grossAmount                Decimal          @default(0) @db.Decimal(12, 2)
  deductionAmount            Decimal          @default(0) @db.Decimal(12, 2)
  netAmount                  Decimal          @default(0) @db.Decimal(12, 2)
  pfEmployeeAmount           Decimal          @default(0) @db.Decimal(12, 2)
  pfEmployerAmount           Decimal          @default(0) @db.Decimal(12, 2)
  tdsAmount                  Decimal          @default(0) @db.Decimal(12, 2)
  generatedById              String?
  approvedById               String?
  postedById                 String?
  paidById                   String?
  approvedAt                 DateTime?
  postedAt                   DateTime?
  paidAt                     DateTime?
  journalEntryId             String?
  disbursementJournalEntryId String?
  notes                      String?
  reversalReason             String?
  reversalAt                 DateTime?
  reversedById               String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fiscalYear FiscalYear?   @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  reversedBy User?         @relation("ReversedPayrollRuns", fields: [reversedById], references: [id], onDelete: SetNull)
  lines      PayrollLine[]
  payslips   Payslip[]

  @@unique([tenantId, periodMonth, periodYear])
  @@index([tenantId, status])
}

model PayrollLine {
  id                String               @id @default(uuid())
  tenantId          String
  payrollRunId      String
  staffId           String
  contractId        String?
  salaryStructureId String?
  basicSalary       Decimal              @default(0) @db.Decimal(12, 2)
  earnings          Decimal              @default(0) @db.Decimal(12, 2)
  grossSalary       Decimal              @db.Decimal(12, 2)
  allowances        Decimal              @default(0) @db.Decimal(12, 2)
  leaveDeductions   Decimal              @default(0) @db.Decimal(12, 2)
  pfEmployee        Decimal              @default(0) @db.Decimal(12, 2)
  pfEmployer        Decimal              @default(0) @db.Decimal(12, 2)
  tds               Decimal              @default(0) @db.Decimal(12, 2)
  otherDeductions   Decimal              @default(0) @db.Decimal(12, 2)
  deductions        Decimal              @default(0) @db.Decimal(12, 2)
  netSalary         Decimal              @db.Decimal(12, 2)
  paidDays          Decimal              @default(0) @db.Decimal(8, 2)
  unpaidDays        Decimal              @default(0) @db.Decimal(8, 2)
  attendanceDays    Int                  @default(0)
  workingDays       Int                  @default(0)
  paymentStatus     PayrollPaymentStatus @default(UNPAID)
  status            PayrollLineStatus    @default(DRAFT)
  createdAt         DateTime             @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  payrollRun      PayrollRun       @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staff           Staff            @relation(fields: [staffId], references: [id], onDelete: Restrict)
  contract        StaffContract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  salaryStructure SalaryStructure? @relation(fields: [salaryStructureId], references: [id], onDelete: SetNull)
  payslip         Payslip?

  @@unique([tenantId, payrollRunId, staffId])
}

model Payslip {
  id              String               @id @default(uuid())
  tenantId        String
  payrollRunId    String
  payrollLineId   String               @unique
  staffId         String
  payslipNumber   String
  status          PayslipStatus        @default(DRAFT)
  grossSalary     Decimal              @db.Decimal(12, 2)
  deductionAmount Decimal              @db.Decimal(12, 2)
  pfEmployee      Decimal              @default(0) @db.Decimal(12, 2)
  pfEmployer      Decimal              @default(0) @db.Decimal(12, 2)
  tds             Decimal              @default(0) @db.Decimal(12, 2)
  netSalary       Decimal              @db.Decimal(12, 2)
  paymentStatus   PayrollPaymentStatus @default(UNPAID)
  generatedAt     DateTime             @default(now())
  issuedAt        DateTime?
  createdAt       DateTime             @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  payrollRun  PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  payrollLine PayrollLine @relation(fields: [payrollLineId], references: [id], onDelete: Cascade)
  staff       Staff       @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@unique([tenantId, payslipNumber])
}
