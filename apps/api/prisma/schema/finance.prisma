model FeeHead {
  id            String       @id @default(uuid())
  tenantId      String
  code          String
  name          String
  frequency     FeeFrequency
  defaultAmount Decimal      @db.Decimal(12, 2)
  vatApplicable Boolean      @default(true)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  feePlanItems  FeePlanItem[]
  invoiceLines  InvoiceLine[]
  discountRules DiscountRule[]
  waivers       FeeWaiver[]

  @@unique([tenantId, code])
}

model FeePlan {
  id             String   @id @default(uuid())
  tenantId       String
  academicYearId String
  classId        String?
  code           String
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  academicYear          AcademicYear           @relation(fields: [academicYearId], references: [id])
  class                 Class?                 @relation(fields: [classId], references: [id])
  items                 FeePlanItem[]
  studentFeeAssignments StudentFeeAssignment[]
  billingRuns           FeeBillingRun[]
  dueSchedules          FeeDueSchedule[]
  discountRules         DiscountRule[]

  @@unique([tenantId, code])
}

model FeePlanItem {
  id        String   @id @default(uuid())
  tenantId  String
  feePlanId String
  feeHeadId String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  feePlan FeePlan @relation(fields: [feePlanId], references: [id])
  feeHead FeeHead @relation(fields: [feeHeadId], references: [id])

  @@unique([feePlanId, feeHeadId])
}

model StudentFeeAssignment {
  id             String   @id @default(uuid())
  tenantId       String
  studentId      String
  feePlanId      String
  academicYearId String
  assignedAt     DateTime @default(now())
  isActive       Boolean  @default(true)

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  student              Student               @relation(fields: [studentId], references: [id])
  feePlan              FeePlan               @relation(fields: [feePlanId], references: [id])
  academicYear         AcademicYear          @relation(fields: [academicYearId], references: [id])
  transportEnrollments TransportEnrollment[]

  @@unique([studentId, feePlanId, academicYearId])
}

model Invoice {
  id                String        @id @default(uuid())
  tenantId          String
  studentId         String
  academicYearId    String
  enrollmentId      String?
  billingRunId      String?
  invoiceNumber     String
  fiscalYear        String?
  billNumber        String?
  dueDate           DateTime
  status            InvoiceStatus @default(ISSUED)
  reportCardBlocked Boolean       @default(false)
  hallTicketBlocked Boolean       @default(false)
  subtotal          Decimal       @db.Decimal(12, 2)
  vatAmount         Decimal       @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  issuedAt          DateTime      @default(now())
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  student       Student        @relation(fields: [studentId], references: [id])
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id])
  enrollment    Enrollment?    @relation(fields: [enrollmentId], references: [id])
  billingRun    FeeBillingRun? @relation(fields: [billingRunId], references: [id])
  lines         InvoiceLine[]
  payments      Payment[]
  onlinePaymentIntents OnlinePaymentIntent[]
  libraryIssues LibraryIssue[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, studentId, status])
  @@index([tenantId, academicYearId, studentId])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  tenantId    String
  invoiceId   String
  feeHeadId   String
  description String
  quantity    Int      @default(1)
  unitAmount  Decimal  @db.Decimal(12, 2)
  vatAmount   Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  feeHead FeeHead @relation(fields: [feeHeadId], references: [id])
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String
  studentId       String
  invoiceId       String
  collectedById   String?
  method          PaymentMethod
  status          PaymentStatus @default(SUCCESS)
  referenceNumber String?
  amount          Decimal       @db.Decimal(12, 2)
  isAdvance       Boolean       @default(false)
  recognizedAt    DateTime?
  reversedAt      DateTime?
  reversedById    String?
  reversalReason  String?
  metadata        Json?
  paidAt          DateTime
  narration       String?
  idempotencyKey  String?
  createdAt       DateTime      @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id])
  invoice     Invoice         @relation(fields: [invoiceId], references: [id])
  collectedBy User?           @relation("CollectedPayments", fields: [collectedById], references: [id])
  reversedBy  User?                  @relation("ReversedPayments", fields: [reversedById], references: [id])
  receipt     Receipt?
  refunds     PaymentRefund[]
  financeApprovalRequests FinanceApprovalRequest[]
  onlinePaymentIntents OnlinePaymentIntent[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, method, referenceNumber])
  @@index([tenantId, paidAt, status])
  @@index([tenantId, studentId, paidAt])
}

model OnlinePaymentIntent {
  id                String                    @id @default(uuid())
  tenantId          String
  studentId         String
  invoiceId         String
  paymentId         String?
  requestedByUserId String
  provider          String
  providerReference String?
  idempotencyKey    String
  amount            Decimal                   @db.Decimal(12, 2)
  currency          String                    @default("NPR")
  status            OnlinePaymentIntentStatus @default(CREATED)
  checkoutUrl       String?
  expiresAt         DateTime?
  failureCode       String?
  failureMessage    String?
  reconciledAt      DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@unique([provider, providerReference])
  @@index([tenantId, studentId, createdAt])
  @@index([tenantId, invoiceId, status])
}

model PaymentRefund {
  id              String   @id @default(uuid())
  tenantId        String
  paymentId       String
  refundNumber    String
  amount          Decimal  @db.Decimal(12, 2)
  refundDate      DateTime
  reason          String
  referenceNumber String?
  narration       String?
  createdById     String?
  createdAt       DateTime @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  payment   Payment @relation(fields: [paymentId], references: [id])
  createdBy User?   @relation("CreatedPaymentRefunds", fields: [createdById], references: [id])

  @@unique([tenantId, refundNumber])
  @@index([tenantId, refundDate])
  @@index([paymentId])
}

model CashierClose {
  id                    String         @id @default(uuid())
  tenantId              String
  closeNumber           String
  closeWindowKey        String?
  openedAt              DateTime
  closedAt              DateTime
  collectorUserId       String?
  paymentMethod         PaymentMethod?
  grossCollected        Decimal        @db.Decimal(12, 2)
  totalRefunded         Decimal        @db.Decimal(12, 2)
  netCollected          Decimal        @db.Decimal(12, 2)
  expectedCashAmount    Decimal?       @db.Decimal(12, 2)
  actualCashAmount      Decimal?       @db.Decimal(12, 2)
  varianceAmount        Decimal?       @db.Decimal(12, 2)
  varianceReason        String?
  denominationBreakdown Json?
  methodBreakdown       Json?
  paymentCount          Int
  refundCount           Int
  firstReceiptNumber    String?
  lastReceiptNumber     String?
  notes                 String?
  closedById            String?
  createdAt             DateTime       @default(now())

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  collectorUser User?  @relation("CashierCloseCollector", fields: [collectorUserId], references: [id], onDelete: SetNull)
  closedBy      User?  @relation("ClosedCashierCloses", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, closeNumber])
  @@unique([tenantId, closeWindowKey])
  @@index([tenantId, openedAt, closedAt])
  @@index([tenantId, collectorUserId, paymentMethod])
}

model Receipt {
  id            String   @id @default(uuid())
  tenantId      String
  paymentId     String   @unique
  receiptNumber String
  fiscalYear    String?
  schoolPan     String?
  vatAmount     Decimal  @default(0) @db.Decimal(12, 2)
  metadata      Json?
  pdfUrl        String?
  issuedAt      DateTime @default(now())

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  payment        Payment                 @relation(fields: [paymentId], references: [id])
  reprintHistory ReceiptReprintHistory[]

  @@unique([tenantId, receiptNumber])
  @@index([tenantId, issuedAt])
}

model ReceiptReprintHistory {
  id            String   @id @default(uuid())
  tenantId      String
  receiptId     String
  paymentId     String?
  studentId     String?
  fileAssetId   String?
  reprintedById String?
  reprintedAt   DateTime @default(now())
  reason        String
  format        String   @default("pdf")
  delivery      String   @default("download")
  metadata      Json?

  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  reprintedBy User?   @relation("ReceiptReprinter", fields: [reprintedById], references: [id], onDelete: SetNull)

  @@index([tenantId, receiptId])
  @@index([tenantId, studentId, reprintedAt])
  @@index([tenantId, paymentId])
}

model FeeDueSchedule {
  id              String    @id @default(uuid())
  tenantId        String
  academicYearId  String
  feePlanId       String?
  name            String
  scheduleType    String
  runMonth        Int?
  runYear         Int?
  dueDate         DateTime
  reminderDays    Int[]
  stopOnPaid      Boolean   @default(true)
  isActive        Boolean   @default(true)
  lastProcessedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  feePlan      FeePlan?     @relation(fields: [feePlanId], references: [id], onDelete: SetNull)

  @@index([tenantId, academicYearId, isActive])
}

model FeeBillingRun {
  id             String           @id @default(uuid())
  tenantId       String
  academicYearId String
  feePlanId      String?
  runMonth       Int
  runYear        Int
  status         BillingRunStatus @default(GENERATED)
  generatedAt    DateTime         @default(now())
  generatedById  String?
  notes          String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  feePlan      FeePlan?     @relation(fields: [feePlanId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@unique([tenantId, academicYearId, runMonth, runYear, feePlanId])
}

model DiscountRule {
  id         String       @id @default(uuid())
  tenantId   String
  name       String
  type       DiscountType
  feeHeadId  String?
  classId    String?
  feePlanId  String?
  percentOff Decimal?     @db.Decimal(5, 2)
  amountOff  Decimal?     @db.Decimal(12, 2)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  feeHead FeeHead? @relation(fields: [feeHeadId], references: [id], onDelete: SetNull)
  class   Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  feePlan FeePlan? @relation(fields: [feePlanId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, isActive])
}

model FeeWaiver {
  id           String       @id @default(uuid())
  tenantId     String
  studentId    String
  feeHeadId    String?
  invoiceId    String?
  amount       Decimal      @db.Decimal(12, 2)
  reason       String
  status       WaiverStatus @default(APPROVED)
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeHead    FeeHead? @relation(fields: [feeHeadId], references: [id], onDelete: SetNull)
  approvedBy User?    @relation("ApprovedFeeWaivers", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId, studentId, status])
}

model FinanceApprovalRequest {
  id            String               @id @default(uuid())
  tenantId      String
  type          FinanceRequestType
  paymentId     String
  amount        Decimal?             @db.Decimal(12, 2)
  reason        String
  status        FinanceRequestStatus @default(PENDING)
  requestedById String
  reviewedById  String?
  reviewNote    String?
  reviewedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("RequestedFinanceApprovals", fields: [requestedById], references: [id])
  reviewedBy  User?   @relation("ReviewedFinanceApprovals", fields: [reviewedById], references: [id])

  @@index([tenantId, status])
  @@index([paymentId])
}
