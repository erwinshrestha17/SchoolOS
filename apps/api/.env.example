NODE_ENV=development
ALLOW_PROD_BOOT=false
PORT=4000

# Matches the root docker-compose.yml Postgres service on host port 5433.
DATABASE_URL=postgresql://schoolos:password123@localhost:5433/schoolos_db?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_CHALLENGE_SECRET=replace-with-a-second-long-random-secret
TOKEN_HASH_PEPPER=replace-with-a-third-long-random-secret
JWT_ISSUER=schoolos
JWT_AUDIENCE_WEB=schoolos-web
JWT_AUDIENCE_MOBILE=schoolos-mobile
JWT_ACCESS_TTL=15m
JWT_CHALLENGE_TTL=10m
JWT_REFRESH_TTL_DAYS=7

BCRYPT_ROUNDS=12

REFRESH_COOKIE_NAME=school_os_refresh_token
ACCESS_COOKIE_NAME=school_os_access_token
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
FRONTEND_ORIGIN=http://localhost:3000
PASSWORD_RESET_APP_URL=http://localhost:3000/reset-password
SCHOOLOS_DEMO_PASSWORDS_REQUIRE_CHANGE=true
SCHOOLOS_DEMO_RESET_CREDENTIALS_ON_SEED=false
PLATFORM_SEED_PASSWORD_REQUIRE_CHANGE=true
PLATFORM_SEED_RESET_CREDENTIALS_ON_SEED=false
TRUST_PROXY=false

OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=15
OTP_LENGTH=6
OTP_ISSUE_LIMIT=3
OTP_ISSUE_WINDOW_MINUTES=15

EMAIL_DELIVERY_MODE=log
EMAIL_FROM_ADDRESS=no-reply@schoolos.local
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=

# Mobile push stays unavailable until both the app Firebase dart-defines and
# an enabled backend provider adapter are configured and verified.
PUSH_PROVIDER_MODE=disabled
PUSH_PROVIDER_ENABLED=false
PUSH_PROVIDER_READY=false
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_TOKEN=

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage
LOCAL_STORAGE_PUBLIC_BASE_URL=/storage
STORAGE_SIGNED_READ_URL_TTL_SECONDS=300
STORAGE_SIGNED_UPLOAD_URL_TTL_SECONDS=300
STORAGE_SIGNING_SECRET=

# Set STORAGE_PROVIDER=s3, r2, or minio to use an S3-compatible store.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_FORCE_PATH_STYLE=false

# Backward-compatible R2 aliases kept during migration.
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PUBLIC_BASE_URL=
