{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@schoolos/core": ["packages/core/src/index.ts"],
      "@schoolos/core/*": ["packages/core/src/*"]
    }
  }
}
